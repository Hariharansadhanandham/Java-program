import java.util.Scanner;

class Codechef {
    public static void main(String[] args) throws java.lang.Exception {
        Scanner sc = new Scanner(System.in);
        
        if (sc.hasNextInt()) {
            int t = sc.nextInt();
            while (t-- > 0) {
                int n = sc.nextInt();
                int rev = 0;
                
                while (n > 0) {
                    int digit = n % 10;
                    rev = rev * 10 + digit;
                    n = n / 10;
                }
                // Print the result followed by a newline
                System.out.println(rev);
            }
        }
        sc.close();
    }
}
